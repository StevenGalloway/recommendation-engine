# Copy this file to .env and adjust values for your environment.
# All variables are optional — shown values are the defaults.

# Allowed CORS origins (JSON array of strings)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Hard cap on recommendations returned per request
MAX_RECOMMENDATIONS=50

# slowapi rate limit expression for POST /v1/recommend
RATE_LIMIT_RECOMMEND=10/minute

# Jikan API settings
JIKAN_TIMEOUT_SECONDS=10.0
JIKAN_MAX_RETRIES=3
JIKAN_CIRCUIT_THRESHOLD=3
JIKAN_CIRCUIT_RESET_SECONDS=60.0
